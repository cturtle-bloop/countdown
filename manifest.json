    "manifest_version": 3,
    "name": "Countdown",
    "version": "0.0.2",
    "description": "Side-panel hold timer with Google-style digit input.",
    "permissions": ["sidePanel", "storage"],
    "action": { "default_title": "Open side panel" },
    "background": { "service_worker": "sw.js" },
    "side_panel": { "default_path": "panel.html" }
  }
  